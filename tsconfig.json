{
  "$schema": "https://raw.githubusercontent.com/Effect-TS/language-service/refs/heads/main/schema.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  },
  "include": [
    "src",
    // Type-level DTO conformance (tests/dto-conformance.test-d.ts): a single file, not the whole
    // tests/ tree — kept out of "src" to live alongside the rest of the test suite, but this repo's
    // tests/ directory has never been part of the tsc program, so it's named explicitly rather than
    // widening "include" to "tests" (which would newly type-check ~100 untyped test files at once).
    "tests/dto-conformance.test-d.ts"
  ]
}
