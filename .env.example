# glance configuration — copy to `.env` and uncomment what you need.
#
# Bun auto-loads `.env` from the directory you launch from, so a `.env` next to
# this file is read by `glance up` with no flag. Every line here is OPTIONAL:
# glance boots with none set (file mode, loopback bind). Real exported vars
# override the file. Leave values commented — an empty `KEY=` sets the var to ""
# and can defeat the default (e.g. OMP_SQUAD_PORT= becomes port 0).
#
# This file is kept complete by tests/env-example.test.ts: every env var read in
# src/ must appear below, and nothing here may be unread. If that test fails,
# add/remove the named var here. (Pilot vars consumed only by scripts/ — e.g. the
# ARCHIL_* section — are forward-declared config and exempt from the src/ check,
# as are a handful of explicitly allowlisted vars the test names and justifies
# inline — e.g. a documented knob whose implementation hasn't landed yet.)

# ── Daemon / bind ────────────────────────────────────────────────────────────
# OMP_SQUAD_PORT=7878                 # daemon port (backs --port)
# OMP_SQUAD_HOST=127.0.0.1            # bind address; 0.0.0.0 exposes on LAN/tailnet (backs --host)
# OMP_SQUAD_INSECURE=0                # set 1 to allow a non-loopback PLAINTEXT bind (token crosses the wire); default refuses
# GLANCE_STATE_DIR=~/.glance          # state.json, access-token, push keys. Default: ~/.glance, or an
#                                     # existing legacy ~/.omp/squad (legacy alias: OMP_SQUAD_STATE_DIR)
# OMP_EXT_DIR=~/.omp/agent/extensions # where the omp extension hooks install
# OMP_SQUAD_STORAGE_BACKEND=local     # local (default) | archil — storage backend for state.json etc; archil is the parked pilot stub (docs/archil-pilot.md)
# GLANCE_REV=                         # optional launch pin: the git rev this daemon was built from; `glance doctor` compares it against the operator's checkout when reported
# OMP_SQUAD_ASK_TIMEOUT_MS=1800000    # how long `glance ask` waits for the written answer before handing back a read-later id

# ── Harness selection (which agent binary/CLI a spawn actually runs) ─────────
# GLANCE_HARNESS=omp                  # operator's global default harness name; falls back to "omp"
# GLANCE_BIN=                         # override argv[0] for the DEFAULT harness only (e.g. a custom omp build); a per-agent bin still wins
# OMP_BIN=omp                         # binary the standalone convergence-run (/loop) uses for its one-shot LLM classify call
# OMP_SQUAD_UNVERIFIED_HARNESS=0      # 1 lets unverified harnesses (codex/gemini) surface on create UIs; never implies a second live provider lane
# OMP_SQUAD_HARNESS_SCORECARD=1       # advisory per-harness success/veto scorecard logging (free, no LLM call); ON unless 0
# OMP_SQUAD_PROFILES=                 # JSON capability-profile bundle (agent-profiles.ts); full trust, unlike a repo-sourced .glance/profiles.json
# OMP_SQUAD_MODELS=                   # comma/newline-separated extra model choices surfaced in the create-agent UI, in addition to the omp default

# ── TLS (both required to enable in-process HTTPS) ───────────────────────────
# OMP_SQUAD_TLS_CERT=                 # PEM cert path
# OMP_SQUAD_TLS_KEY=                  # PEM key path

# ── Auth & multi-tenant (DB mode) ────────────────────────────────────────────
# DATABASE_URL=                       # postgres://… or sqlite:<path>/<path>; unset = file mode
# BETTER_AUTH_SECRET=                 # session-signing secret; REQUIRED on a non-loopback DB bind — openssl rand -hex 32
# BETTER_AUTH_URL=                    # public https origin behind a TLS tunnel (origin check + Secure cookie)
# OMP_SQUAD_ALLOW_SIGNUP=0            # 1 opens self-service sign-up; default closed (invite/bootstrap only)
# GITHUB_CLIENT_ID=                   # GitHub OAuth app client id; enables "Login with GitHub" (needs both id+secret)
# GITHUB_CLIENT_SECRET=               # GitHub OAuth app client secret. Callback URL on the app: <BETTER_AUTH_URL>/api/auth/callback/github
# ── Enterprise SSO via WorkOS (AuthKit → one OIDC upstream for every customer IdP + social) ──
# WORKOS_CLIENT_ID=                   # WorkOS Client ID (client_...); enables "Sign in with SSO" (needs id+key). See docs/workos-sso.md
# WORKOS_API_KEY=                     # WorkOS API key (sk_...); doubles as the OIDC client secret. Redirect URI: <BETTER_AUTH_URL>/api/auth/oauth2/callback/workos
# WORKOS_WEBHOOK_SECRET=              # per-endpoint signing secret for the Directory Sync (SCIM) webhook at /api/workos/webhook
# OMP_SQUAD_OPERATOR_TOKEN=           # file-mode extra bearer token mapped to the operator role
# OMP_SQUAD_VIEWER_TOKEN=             # file-mode extra bearer token mapped to viewer (read-only)
# OMP_SQUAD_ORG_IDLE_MS=600000        # evict an idle org manager after this many ms (DB mode)
# OMP_SQUAD_ROOT_ORG=                 # DB mode: which org the on-box loopback admin + root factory route to; unset = per-tenant registry only

# ── Autonomy ─────────────────────────────────────────────────────────────────
# OMP_SQUAD_AUTODRIVE=1               # orchestrator autonomy loop; ON unless 0
# OMP_SQUAD_AUTOLAND=1                # auto-land GREEN branches; ON unless 0
# OMP_SQUAD_LAND_CONFIRM=1            # stage a one-tap Land instead of blind-merging; ON unless 0
# OMP_SQUAD_AUTORESOLVE=1             # auto-resolve rebase conflicts during land; ON unless 0
# OMP_SQUAD_AUTORESOLVE_CONFIRM=1     # an AUTO resolved-conflict land stages for a one-tap Land instead of merging; ON unless 0
# OMP_SQUAD_AUTOLAND_FAIL_CAP=3       # consecutive failed auto-lands before parking + filing a bug
# OMP_SQUAD_MAX_WIP=                  # live-agent cap; default ~half the host's CPUs (min 2)
# OMP_SQUAD_WIP_CAP=3                 # the wipCap NUMBER surfaced in the /api status/health payload; a separate
#                                     # knob from OMP_SQUAD_MAX_WIP above — not the scheduler's own enforcement cap
# OMP_SQUAD_MAX_AGENTS=               # hard ceiling on host processes; default max(CPUs, 3)
# OMP_SQUAD_QUEUE_ON_FULL=0           # queue spawns past the WIP cap instead of throwing; default off
# OMP_SQUAD_REPAIR_BUDGET=3           # gate-repair retries before escalating to a human
# OMP_SQUAD_LLM_ROUTER=0              # LLM intake routing instead of heuristics; default off
# OMP_SQUAD_REGRESSION_GATE=1         # post-merge full-suite regression check; ON unless 0
# OMP_SQUAD_ROOT_FACTORY=0            # DB mode: stand up a single root SquadManager owning the global Plane loops; needs PLANE_PROJECT_MAP too; default off
# OMP_SQUAD_TDD=                      # 0 disables the TDD (write-test-first) variant globally; "force" emits it on every verify-routed task; unset = heuristic
# OMP_SQUAD_TDD_TESTER_MODEL=         # model for the isolated TDD test-author thread; unset = same model as the implementer
# OMP_SQUAD_STALE_GATE=1              # block a stale (rebase-needed) branch from merging unchecked; ON unless 0
# OMP_SQUAD_GATE_CONCURRENCY=1        # max concurrent gated (verify/proof) commands
# OMP_SQUAD_WIP_SWEEP_DWELL_MS=3000   # idle-dwell before the land WIP sweep will freeze an agent's tree into a commit
# OMP_SQUAD_PENDING_GHOST_EXPIRY=0    # 1 enables the extra heuristic pending-request expiry path (on top of the always-on proof-based replay-tag expiry)
# OMP_SQUAD_POLICY_RULES=0            # enforce operator-defined deny/ask rules on agent tool calls, on top of the built-in guardrails; default off
# OMP_SQUAD_MEMBRANE_PROFILES=0       # let implementer profiles opt into prompt-only output disciplines (membrane:verdict-first / membrane:minimal-code); default off
# OMP_SQUAD_ACP_CONTEXT=none          # "prompt" injects glance context (fabric primer + tool-grant scoping) into ACP harnesses that have no system-prompt slot; default none (unscoped)

# ── Land / PR ─────────────────────────────────────────────────────────────────
# OMP_SQUAD_LAND_MODE=auto            # auto (probe) | local | pr — bypass the land-mode probe entirely with local/pr
# OMP_SQUAD_LAND_MODE_TTL_MS=300000   # cache TTL for a repo's resolved land mode (5 min default)
# OMP_SQUAD_PR_BASE=                  # override the fork-base / default branch used for PR creation and ahead-of-base arithmetic
# OMP_SQUAD_PR_DRAFT=1                # open landing PRs as drafts; set 0 to open them ready for review
# OMP_SQUAD_PR_MERGE_METHOD=merge     # merge | squash | rebase
# OMP_SQUAD_PR_RECONCILE_INTERVAL_MS=120000 # ms between reconcile ticks that write Done for merged-but-unreconciled PRs
# OMP_SQUAD_LAND_RISK_GATE=0          # block a large/sensitive-path diff from auto-landing unattended, leaving it for a human Land review; default off
# OMP_SQUAD_LAND_MAX_DIFF_FILES=40    # file-count threshold the land-risk gate blocks at
# OMP_SQUAD_LAND_BLOCKED_ESCALATE_CAP=20 # consecutive land-blocked attempts on the same episode before filing a "Needs you" attention item; 0 disables
# OMP_SQUAD_AHEAD_UNKNOWN_ESCALATE_CAP=3 # consecutive ahead-of-base probe FAULTS (git couldn't answer) on one unit before a "Needs you" attention item; 0 disables
# OMP_SQUAD_PRODUCES_ALLOW=           # comma-separated extra allowlist patterns for out-of-scope-write auditing (on top of an agent's declared produces/owns)
# OMP_SQUAD_VETO_REPROMPT=0           # feed a validator veto's reason back into the same unit's next turn once per veto cycle; default off

# ── Model routing & cost projection ──────────────────────────────────────────
# OMP_SQUAD_MODEL_OUTCOMES=0          # route a unit's model from the task-class×model outcomes matrix when the caller didn't pick one; default off
# OMP_SQUAD_MODEL_ROUTE_SHADOW=1      # log the routing decision without applying it; set 0 to actually apply the routed model
# OMP_SQUAD_COST_GATE=off             # off (default) | shadow (log only) | enforce (reserved — treated as shadow in v1)
# OMP_SQUAD_COST_MAX_PER_CHANGE=      # $ ceiling per landed change; unset/<=0 = no verdict (silent)
# OMP_SQUAD_COST_MIN_SAMPLE=5         # minimum (model, tier) attempts before the cost gate will render a verdict

# ── Validator (independent judge) + lens review panel ────────────────────────
# OMP_SQUAD_VALIDATOR=1               # independent-judge gate on landing verdicts; ON unless 0
# OMP_SQUAD_VALIDATOR_MODEL=opus      # model for the judge call, independent of the executor's model default
# OMP_SQUAD_VALIDATOR_HARNESS=omp     # omp (default, Claude-lineage judge) | codex (OpenAI-lineage judge, opt-in)
# OMP_SQUAD_VALIDATOR_TIMEOUT_MS=120000 # timeout for the omp-harness judge call
# OMP_SQUAD_VALIDATOR_CODEX_TIMEOUT_MS=90000 # timeout for the codex-harness judge call
# OMP_SQUAD_VALIDATOR_GROK_TIMEOUT_MS=120000 # timeout for the grok-harness (xai third-lineage) judge call
# OMP_SQUAD_LENS_REVIEW=0             # master flag for the perspective-diversified (out-of-criteria) lens panel; default off
# OMP_SQUAD_LENS_SET=                 # comma-separated allowlist of lens ids, intersected with the known lenses; unset = no restriction
# OMP_SQUAD_LENS_MAX=1                # how many lenses may fire per review; 0 disables the panel even with the master flag on
# OMP_SQUAD_LENS_VERIFY=0             # sub-flag: re-check a lens objection against the diff before it counts; only meaningful with LENS_REVIEW on
# OMP_SQUAD_LENS_TIMEOUT_MS=60000     # per-lens judge call timeout

# ── Sentinel (drift monitor) ─────────────────────────────────────────────────
# OMP_SQUAD_SENTINEL=0                # opt-in reasoning-drift classification sweep (inverse of Scout's default-on); default off
# OMP_SQUAD_SENTINEL_MAX_CALLS_PER_HOUR=30 # per-hour drift-classification LLM call budget; <=0 = unlimited
# OMP_SQUAD_SENTINEL_DENY=            # comma-separated agent ids/names EXCLUDED from drift monitoring even when they declare acceptance criteria

# ── Trace / observability ────────────────────────────────────────────────────
# OMP_SQUAD_TRACE=1                   # keep trace ids; set 0 to omit fine spans/export while preserving receipt rollups
# OMP_SQUAD_TRACE_SAMPLE=0.1          # tail-sample OK run spans; errors are always kept
# OMP_SQUAD_TRACE_MAX_SPANS=500       # per-run fine span cap; oldest OK tool spans shed first
# OMP_SQUAD_TRACE_EXPORT_QUEUE=1000   # bounded in-memory export queue; drop-oldest on overflow
# OMP_SQUAD_TRACE_EXPORT_TIMEOUT_MS=5000 # per-export HTTP timeout
# OMP_SQUAD_TRACE_ALLOW_PRIVATE=0     # set 1 to reach operator-configured private/loopback OTLP/Datadog/Langfuse collectors (SSRF-strict by default — only the configured collector origins are exempted)
# OMP_SQUAD_TRACE_EXPORT_OTLP_URL=    # OTLP/HTTP JSON endpoint (ssrf-guarded)
# OMP_SQUAD_TRACE_EXPORT_LANGFUSE_URL= # Langfuse ingest endpoint (ssrf-guarded)
# OMP_SQUAD_TRACE_EXPORT_LANGFUSE_PUBLIC_KEY=
# OMP_SQUAD_TRACE_EXPORT_LANGFUSE_SECRET_KEY=
# OMP_SQUAD_TRACE_EXPORT_DATADOG_URL= # Datadog trace ingest endpoint (ssrf-guarded)
# OMP_SQUAD_TRACE_EXPORT_DATADOG_API_KEY=
# OMP_SQUAD_TRACE_LOCAL=1              # also write traces.jsonl under the state dir; ON unless 0

# ── Auto-supervisor (answers blocked agents hands-free) ──────────────────────
# OMP_SQUAD_AUTO_SUPERVISE=1          # standing EXTERNAL supervisor loop (file mode only); ON unless 0
# OMP_SQUAD_SUPERVISE_MODEL=          # model for the supervisor answerer; empty = omp default
# OMP_SQUAD_AUTOSUPERVISE=1           # manager-side deterministic auto-answer; ON unless 0
# OMP_SQUAD_AUTOSUPERVISE_BUDGET=5    # per-agent cap on those auto-answers

# ── Dispatch (Plane-issue driven; needs Plane configured below) ──────────────
# OMP_SQUAD_AUTODISPATCH=1            # Plane-issue dispatcher loop; ON unless 0
# OMP_SQUAD_AUTOCLOSE=1               # close the tracking Plane issue when a branch lands; ON unless 0
# OMP_SQUAD_DISPATCH_INTERVAL_MS=60000 # ms between dispatch sweeps
# OMP_SQUAD_DISPATCH_MAX=3            # max agents the dispatcher keeps active at once
# OMP_SQUAD_SPEC_MAX_CHARS=4000       # truncate an over-long dispatched issue body to this many chars

# ── Observer (files findings as Plane issues; needs Plane configured) ────────
# OMP_SQUAD_OBSERVE=1                 # fleet observer; ON unless 0
# OMP_SQUAD_OBSERVE_MAX=10            # cap on observer-filed OPEN issues
# OMP_SQUAD_OBSERVE_AUTODISPATCH=0    # 1 files findings without the triage marker (auto-dispatched)
# OMP_SQUAD_OBSERVE_AUTOFIX=0         # 1 actions autoFixable findings directly instead of filing
# OMP_SQUAD_OBSERVE_REPRODUCE=0       # 1 dispatches an observing agent to reproduce a confirmed regression instead of only filing it

# ── Scout (LLM-driven reasoning scan) ───────────────────────────────────────
# OMP_SQUAD_SCOUT=1                   # reasoning-scout backlog harvest; ON unless 0
# OMP_SQUAD_SCOUT_MAX_CALLS_PER_HOUR=30 # cap on Scout LLM calls/hour; 0 or negative = unlimited
# OMP_SQUAD_SCOUT_MAX=20              # cap on scout-filed OPEN issues
# OMP_SQUAD_SCOUT_PER_RUN=3           # cap on tickets filed from one scan

# ── Learning-loop A/B flags (eap-borrows / sirvir) ───────────────────────────
# OMP_SQUAD_REFLEXION=                # unset | on | off | ab — reflexion-style retry arm
# OMP_SQUAD_REWARD_BOOST=             # unset | on | off | ab — reward-boost learning arm
# OMP_SQUAD_FAILURE_MEMORY=           # unset | on | off | ab — failure-memory learning arm
# OMP_SQUAD_THRESHOLD_TUNER=          # unset | on | off | ab — confidence-threshold auto-tuner arm
# OMP_SQUAD_DECISION_CAPTURE=         # unset | on | off | ab — decision-capture learning arm

# ── Convergence run (autonomous /loop) ───────────────────────────────────────
# OMP_SQUAD_LOOP_ARMED=0              # armed per-process by the /loop entrypoint itself; never set this by hand
# OMP_SQUAD_LOOP_SESSION=             # owning session id stamped into the Stop-hook arm sentinel; falls back to CLAUDE_SESSION_ID
# CLAUDE_SESSION_ID=                  # set automatically by Claude Code; read as a loop-session-id fallback, not operator-configured
# OMP_SQUAD_CONFIDENCE_FLOOR=0.4      # minimum confidence a convergence run will keep iterating below
# OMP_SQUAD_CONVERGENCE_BUDGET_CAP=50 # max iterations before a convergence run gives up
# OMP_SQUAD_CONVERGENCE_EPSILON=0     # minimum measured improvement per iteration to keep going

# ── Reflection (self-heal root-cause on a failed gate) ───────────────────────
# OMP_SQUAD_REFLECT_MODEL=haiku       # model for the one-shot root-cause reflection call
# OMP_SQUAD_REFLECT_TIMEOUT_MS=20000  # timeout for that call

# ── Opportunity clustering (scout-pattern dedup → filed issues) ──────────────
# OMP_SQUAD_OPPORTUNITY=1             # cluster recurring scout patterns into opportunity issues; ON unless 0
# OMP_SQUAD_OPPORTUNITY_MIN=3         # minimum cluster size before it's worth filing
# OMP_SQUAD_OPPORTUNITY_MAX=5         # cap on opportunity issues filed per scan
# OMP_SQUAD_OPPORTUNITY_WINDOW=50     # how many recent scout items a scan clusters over

# ── Resident planner (Epic 1 — plans/<name>/OBJECTIVE.md ↔ concern DAG) ──────
# OMP_SQUAD_RESIDENT_PLANNER=0        # opt-IN (LLM-cost-bearing writer of source-tree plan files); "1" to enable, unlike every loop above

# ── Chat attachments ─────────────────────────────────────────────────────────
# OMP_SQUAD_CHAT_ATTACH_MAX_BYTES=268435456 # hard write-time cap on one org's total chat-attachments footprint (256MB default)
# OMP_SQUAD_CHAT_ATTACH_MAX_DIMENSION_PX=2048 # server-enforced max PNG width/height, independent of client claims
# OMP_SQUAD_CHAT_ATTACH_REAP=1        # opportunistic TTL sweep of stale attachments; ON unless 0
# OMP_SQUAD_CHAT_ATTACH_TTL_MS=2592000000 # age (ms) before a chat attachment is reaped (30 days default)

# ── Terminal attention lane (OSC notify, plans/fleet-ide-bridge) ─────────────
# OMP_SQUAD_OSC_NOTIFY=1              # TUI writes OSC 9/777 desktop-notify sequences on input/error transitions; 0 disables (inert when piped either way)

# ── Voice lane (speech-to-speech console, plans/webapp-voice-lane) ───────────
# OMP_SQUAD_VOICE_ENABLED=0           # 1 enables POST /api/voice/token + GET /api/voice/config; default off
# OMP_SQUAD_VOICE_OPENAI_API_KEY=     # real OpenAI key used server-side ONLY to mint ek_... ephemeral tokens; never sent to the browser
# OMP_SQUAD_VOICE_MODEL=gpt-realtime-2.1 # realtime model pinned server-side into the mint request; browser never chooses it
# OMP_SQUAD_VOICE_VOICE=marin         # realtime voice pinned server-side into the mint request
# OMP_SQUAD_VOICE_MINT_RATE_PER_MIN=6 # per-actor mint rate cap; the daemon's only spend signal since audio never transits it

# ── Per-org voice keys (DB mode only, plans/voice-db-mode) ───────────────────
# OMP_SQUAD_SECRETS_KEY_FILE=         # ISOLATION-SAFE: path to a file holding the 32-byte master key (hex or base64) encrypting org_secret rows (AES-256-GCM). Preferred over OMP_SQUAD_SECRETS_KEY below — the key bytes never enter process.env/the kernel exec-time environ, so they're never readable via /proc/<pid>/environ by another same-uid process (an env var IS readable there even after a same-process `delete process.env.X`, since the kernel's copy predates the delete). Wins over the plain env var when both are set.
# OMP_SQUAD_SECRETS_KEY=              # back-compat: 32-byte master key (hex or base64) directly in the env — leaks via /proc/self/environ even though it's deleted from process.env at boot; prefer OMP_SQUAD_SECRETS_KEY_FILE above. Operator-supplied only — DB mode + voice ENABLED + no usable key (either form) ⇒ the lane reports enabled:false and mint 501s, never a dead daemon. Read once at boot then deleted from process.env (src/secrets.ts)
# OMP_SQUAD_VOICE_TOKEN_TTL_S=120     # ephemeral-token establishment window ONLY, not call length (the provider caps a live session's own duration independently); default 120s kills token hoarding without touching call length
# OMP_SQUAD_VOICE_MAX_CONCURRENT_PER_ORG=5 # durable per-org mint concurrency cap, derived from the audit table (restart-safe, unlike an in-memory map) — refuses a mint once this org has this many unexpired mints inside the provider's own max-session window
# OMP_SQUAD_VOICE_KEY_PUT_RATE_PER_MIN=10 # per-actor rate cap on PUT /api/org/voice-key (each PUT makes one free provider verification call before persisting)

# ── Gate sandbox (WHERE + WHICH env a verify/proof/regression gate runs in) ──
# OMP_SQUAD_GATE_ENV=                 # comma-separated var names to re-admit into a scrubbed gate child's env (e.g. a suite's integration-test key)
# OMP_SQUAD_GATE_SANDBOX=             # image | host/off/0/disable (opt-out) | unset (auto: sandbox if docker is present, else a legible host fallback)
# OMP_SQUAD_GATE_SANDBOX_IMAGE=       # default image used in auto mode; unset = the derived git-enabled local build of the base image
# OMP_SQUAD_GATE_SANDBOX_DISABLE=0    # truthy forces host exec, same as OMP_SQUAD_GATE_SANDBOX=host
# OMP_SQUAD_GATE_SANDBOX_STRICT=0     # 1 fails closed (refuses to run on the host) instead of falling back when docker is absent
# OMP_SQUAD_GATE_SANDBOX_NETWORK=none # container network for the gate sandbox
# OMP_SQUAD_GATE_SANDBOX_USER=        # --user for the gate container; default the daemon's uid:gid, set "root" to restore the old behavior

# ── OpenRouter cost ingestion ────────────────────────────────────────────────
# OPENROUTER_API_KEY=                 # OpenRouter API key; ingestion no-ops (scanned 0) unless this AND the attribution repo are both set
# OPENROUTER_ATTRIBUTION_REPO=        # which repo OpenRouter activity rows are attributed to

# ── Payments (Feedback Loop reward disbursement) ─────────────────────────────
# OMP_SQUAD_TREMENDOUS_API_KEY=       # Tremendous Bearer token; its presence activates real payouts (else ManualProvider)
# OMP_SQUAD_TREMENDOUS_FUNDING_SOURCE_ID= # which balance/account funds the payout
# OMP_SQUAD_TREMENDOUS_CAMPAIGN_ID=   # campaign controlling redemption options the recipient sees
# OMP_SQUAD_TREMENDOUS_ENV=sandbox    # sandbox (default) | production
# OMP_SQUAD_PLAN_MONTHLY=             # $/month subscription cost, for cost-attribution amortization; absent ⇒ no subscription verdict
# OMP_SQUAD_PLAN_NAME=subscription    # label for that plan in the cost-attribution scoreboard

# ── Federation (cross-operator coordination) ─────────────────────────────────
# OMP_SQUAD_FEDERATION=0              # set 0 to opt out; default ON (LocalFederationBus — works without a coordinator)
# OMP_SQUAD_COORDINATOR=              # coordinator WebSocket URL (ws://host:port); enables cross-host peer gossip when set
# OMP_SQUAD_COORDINATOR_PORT=7900     # port the standalone coordinator listens on
# OMP_SQUAD_COORDINATOR_HOST=127.0.0.1 # coordinator bind address; 0.0.0.0 exposes it — needs a token (or OMP_SQUAD_INSECURE=1)
# OMP_SQUAD_COORDINATOR_TOKEN=         # pre-shared relay secret; clients + coordinator must match. Unset = no auth (loopback only)
# OMP_SQUAD_OPERATOR=                 # operator identity in presence/leases/roster; default = OS username
# OMP_SQUAD_FED_REPOS=                # extra repo paths the federation-sync worker advertises (comma-separated)
# OMP_SQUAD_LEASE_GOSSIP_MS=          # interval between peer lease-gossip broadcasts; unset = built-in default
# OMP_SQUAD_PEERMSG_BUDGET=5          # per-peer cap on cross-operator messages

# ── Host pressure / watchdog ─────────────────────────────────────────────────
# OMP_SQUAD_RESOURCE_GATE=0           # enable load-aware admission backoff; default off
# OMP_SQUAD_MAX_RSS_MB=1024           # watchdog per-host RSS ceiling (MB)
# OMP_SQUAD_MAX_LOAD_PER_CPU=         # load1/CPU pressure threshold (watchdog 2.0, admission gate 1.5)
# OMP_SQUAD_MIN_FREE_RATIO=0.1        # minimum free-memory ratio before the host counts as pressured

# ── Worktree reaping ─────────────────────────────────────────────────────────
# OMP_SQUAD_WORKTREE_REAP=1           # reap dead worktrees; ON unless 0
# OMP_SQUAD_WORKTREE_GRACE_MS=120000  # grace period before a dead worktree is reaped

# ── Context heat ─────────────────────────────────────────────────────────────
# OMP_SQUAD_HEAT_HALFLIFE_MS=604800000 # context-heat decay half-life (default 7 days). KNOWN GAP: no
#                                      # context-heat decay consumer reads this today — see tests/env-example.test.ts KNOWN_GAPS.

# ── Web dashboard / push / vision ────────────────────────────────────────────
# OMP_SQUAD_PRIMER_TIMEOUT_MS=5000  # ms budget for the per-spawn fabric snapshot; on timeout the unit spawns unprimed
# OMP_SQUAD_PRIMER_BACKOFF_MS=60000 # after a timeout, skip priming FOR THAT REPO this long (the timed-out
#                                   # fabric read keeps running; without a breaker each queued spawn starts another)
# OMP_SQUAD_CONTEXT_PRIMER=1        # 0 disables the cold-start fabric primer injected into every unit's system prompt
# OMP_SQUAD_ACP_CONTEXT=none        # "prompt" injects glance context into an ACP unit's FIRST TURN (lossy —
#                                   # ACP has no system-prompt slot). Default "none": the unit runs unscoped,
#                                   # and the harness scorecard says so instead of claiming instructions.
# OMP_SQUAD_WEBAPP=0                  # 1 serves webapp/dist (the Vite dashboard) when built
# OMP_SQUAD_PUSH_SUBJECT=mailto:squad@localhost # VAPID `sub` contact for Web Push
# OMP_SQUAD_APP_URL=                  # default URL for the vision (screenshot) pass
# OMP_GRAPH_CACHE_MS=10000            # cache TTL for the omp-graph dashboard history endpoint
# OMP_SQUAD_OPEN_CMD=                 # `glance open` / webapp Open-worktree editor template, e.g. "terax {path}" or
#                                     # "wezterm start --cwd {path}"; whitespace-split argv, NO shell quoting; default: terax, then code, on PATH

# ── Feedback Loop (public screenshot intake) ──────────────────────────────────
# OMP_SQUAD_FEEDBACK=0                 # 1 enables public /api/feedback/items and /feedback/widget.js
# OMP_SQUAD_FEEDBACK_MAX_IMAGE_BYTES=2000000 # max PNG/JPEG data URL payload accepted by public intake
# OMP_SQUAD_FEEDBACK_RATE_LIMIT_PER_MIN=30 # coarse in-process per-campaign+IP public intake limit

# ── Discovery ────────────────────────────────────────────────────────────────
# OMP_SQUAD_REPO_ROOTS=               # comma-separated roots scanned for smart-spawn; default <parent of cwd>,~/sui,~/src,~/code

# ── Plane integration ────────────────────────────────────────────────────────
# PLANE_API_KEY=                      # Plane API key
# PLANE_API_TOKEN=                    # alias for PLANE_API_KEY (lets the daemon read a pasted plane.env)
# PLANE_WORKSPACE=                    # Plane workspace slug
# PLANE_WORKSPACE_SLUG=               # alias for PLANE_WORKSPACE
# PLANE_BASE_URL=https://api.plane.so # API base (a trailing /api/v1 is stripped)
# PLANE_PROJECT_ID=                   # fallback project id when a repo is not in PLANE_PROJECT_MAP
# PLANE_PROJECT_MAP=                  # JSON: { "<repo path>": "<plane project id>" }
# PLANE_APP_URL=                      # web app base for deep links; derived from PLANE_BASE_URL if unset
# OMP_SQUAD_PLANE_CACHE_MS=15000      # TTL for cached successful open-issue list reads
# OMP_SQUAD_PLANE_BACKOFF_BASE_MS=500 # base for exponential 429 backoff when Plane sends no Retry-After
# OMP_SQUAD_PLANE_MIN_INTERVAL_MS=500 # minimum ms between serialized Plane fetches
# OMP_SQUAD_PLANE_MAX_PAGES=4         # how many 50-issue pages the open-work poll fetches; raise for very large backlogs
# OMP_SQUAD_PLANSYNC=1                # keep plans/<x>/NN-concern.md STATUS lines synced against their PLANE: pointer; ON unless 0
# OMP_SQUAD_PLANSYNC_INTERVAL_MS=300000 # ms between plan-sync ticks

# ── Archil collaborative substrate (PILOT — PARKED; see docs/archil-pilot.md) ─
# Forward-declared config for the Archil agentic-OS substrate pilot (plans/archil-mt-pilot/).
# PARKED: not yet provisioned — we are deliberately NOT paying for an Archil account yet.
# These are read by the throwaway pilot scripts in scripts/ (collab-spike-archil.ts,
# durability-archil.ts) once the pilot is un-parked — NOT by src/. Leave commented until a paid
# Archil account + disk exist. Un-park steps: docs/archil-pilot.md.
# ARCHIL_DISK=                        # disk name or id to mount (the synced "trunk" substrate disk)
# ARCHIL_REGION=aws-us-east-1         # region: aws-us-east-1 | aws-us-west-2 | aws-eu-west-1 (exec/branches need an AWS region)
# ARCHIL_MOUNT_TOKEN=                 # disk token for `archil mount` (the SDK also reads it as ARCHIL_DISK_TOKEN)
