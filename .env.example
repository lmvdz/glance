# omp-squad configuration — copy to `.env` and uncomment what you need.
#
# Bun auto-loads `.env` from the directory you launch from, so a `.env` next to
# this file is read by `omp-squad up` with no flag. Every line here is OPTIONAL:
# omp-squad boots with none set (file mode, loopback bind). Real exported vars
# override the file. Leave values commented — an empty `KEY=` sets the var to ""
# and can defeat the default (e.g. OMP_SQUAD_PORT= becomes port 0).
#
# This file is kept complete by tests/env-example.test.ts: every env var read in
# src/ must appear below, and nothing here may be unread. If that test fails,
# add/remove the named var here. (Pilot vars consumed only by scripts/ — e.g. the
# ARCHIL_* section — are forward-declared config and exempt from the src/ check.)

# ── Daemon / bind ────────────────────────────────────────────────────────────
# OMP_SQUAD_PORT=7878                 # daemon port (backs --port)
# OMP_SQUAD_HOST=127.0.0.1            # bind address; 0.0.0.0 exposes on LAN/tailnet (backs --host)
# OMP_SQUAD_INSECURE=0                # set 1 to allow a non-loopback PLAINTEXT bind (token crosses the wire); default refuses
# OMP_SQUAD_STATE_DIR=~/.omp/squad    # state.json, access-token, push keys
# OMP_EXT_DIR=~/.omp/agent/extensions # where the omp extension hooks install

# ── TLS (both required to enable in-process HTTPS) ───────────────────────────
# OMP_SQUAD_TLS_CERT=                 # PEM cert path
# OMP_SQUAD_TLS_KEY=                  # PEM key path

# ── Auth & multi-tenant (DB mode) ────────────────────────────────────────────
# DATABASE_URL=                       # postgres://… or sqlite:<path>/<path>; unset = file mode
# BETTER_AUTH_SECRET=                 # session-signing secret; REQUIRED on a non-loopback DB bind — openssl rand -hex 32
# BETTER_AUTH_URL=                    # public https origin behind a TLS tunnel (origin check + Secure cookie)
# OMP_SQUAD_ALLOW_SIGNUP=0            # 1 opens self-service sign-up; default closed (invite/bootstrap only)
# OMP_SQUAD_OPERATOR_TOKEN=           # file-mode extra bearer token mapped to the operator role
# OMP_SQUAD_VIEWER_TOKEN=             # file-mode extra bearer token mapped to viewer (read-only)
# OMP_SQUAD_ORG_IDLE_MS=600000        # evict an idle org manager after this many ms (DB mode)

# ── Autonomy ─────────────────────────────────────────────────────────────────
# OMP_SQUAD_AUTODRIVE=1               # orchestrator autonomy loop; ON unless 0
# OMP_SQUAD_AUTOLAND=1                # auto-land GREEN branches; ON unless 0
# OMP_SQUAD_LAND_CONFIRM=1            # stage a one-tap Land instead of blind-merging; ON unless 0
# OMP_SQUAD_AUTORESOLVE=1             # auto-resolve rebase conflicts during land; ON unless 0
# OMP_SQUAD_AUTORESOLVE_CONFIRM=1     # an AUTO resolved-conflict land stages for a one-tap Land instead of merging; ON unless 0
# OMP_SQUAD_AUTOLAND_FAIL_CAP=3       # consecutive failed auto-lands before parking + filing a bug
# OMP_SQUAD_MAX_WIP=                  # live-agent cap; default ~half the host's CPUs (min 2)
# OMP_SQUAD_MAX_AGENTS=               # hard ceiling on host processes; default max(CPUs, 3)
# OMP_SQUAD_QUEUE_ON_FULL=0           # queue spawns past the WIP cap instead of throwing; default off
# OMP_SQUAD_REPAIR_BUDGET=3           # gate-repair retries before escalating to a human
# OMP_SQUAD_LLM_ROUTER=0              # LLM intake routing instead of heuristics; default off

# ── Trace / observability ────────────────────────────────────────────────────
# OMP_SQUAD_TRACE=1                   # keep trace ids; set 0 to omit fine spans/export while preserving receipt rollups
# OMP_SQUAD_TRACE_SAMPLE=0.1          # tail-sample OK run spans; errors are always kept
# OMP_SQUAD_TRACE_MAX_SPANS=500       # per-run fine span cap; oldest OK tool spans shed first
# OMP_SQUAD_TRACE_EXPORT_QUEUE=1000   # bounded in-memory export queue; drop-oldest on overflow
# OMP_SQUAD_TRACE_EXPORT_TIMEOUT_MS=5000 # per-export HTTP timeout
# OMP_SQUAD_TRACE_EXPORT_OTLP_URL=    # OTLP/HTTP JSON endpoint (ssrf-guarded)
# OMP_SQUAD_TRACE_EXPORT_LANGFUSE_URL= # Langfuse ingest endpoint (ssrf-guarded)
# OMP_SQUAD_TRACE_EXPORT_LANGFUSE_PUBLIC_KEY=
# OMP_SQUAD_TRACE_EXPORT_LANGFUSE_SECRET_KEY=
# OMP_SQUAD_TRACE_EXPORT_DATADOG_URL= # Datadog trace ingest endpoint (ssrf-guarded)
# OMP_SQUAD_TRACE_EXPORT_DATADOG_API_KEY=

# ── Auto-supervisor (answers blocked agents hands-free) ──────────────────────
# OMP_SQUAD_AUTO_SUPERVISE=1          # standing EXTERNAL supervisor loop (file mode only); ON unless 0
# OMP_SQUAD_SUPERVISE_MODEL=          # model for the supervisor answerer; empty = omp default
# OMP_SQUAD_AUTOSUPERVISE=1           # manager-side deterministic auto-answer; ON unless 0
# OMP_SQUAD_AUTOSUPERVISE_BUDGET=5    # per-agent cap on those auto-answers

# ── Dispatch (Plane-issue driven; needs Plane configured below) ──────────────
# OMP_SQUAD_AUTODISPATCH=1            # Plane-issue dispatcher loop; ON unless 0
# OMP_SQUAD_AUTOCLOSE=1               # close the tracking Plane issue when a branch lands; ON unless 0
# OMP_SQUAD_DISPATCH_INTERVAL_MS=60000 # ms between dispatch sweeps
# OMP_SQUAD_DISPATCH_MAX=3            # max agents the dispatcher keeps active at once

# ── Observer (files findings as Plane issues; needs Plane configured) ────────
# OMP_SQUAD_OBSERVE=1                 # fleet observer; ON unless 0
# OMP_SQUAD_OBSERVE_MAX=10            # cap on observer-filed OPEN issues
# OMP_SQUAD_OBSERVE_AUTODISPATCH=0    # 1 files findings without the triage marker (auto-dispatched)
# OMP_SQUAD_OBSERVE_AUTOFIX=0         # 1 actions autoFixable findings directly instead of filing

# ── Federation (cross-operator coordination) ─────────────────────────────────
# OMP_SQUAD_COORDINATOR=              # coordinator WebSocket URL (ws://host:port); unset = federation inert
# OMP_SQUAD_COORDINATOR_PORT=7900     # port the standalone coordinator listens on
# OMP_SQUAD_COORDINATOR_HOST=127.0.0.1 # coordinator bind address; 0.0.0.0 exposes it — needs a token (or OMP_SQUAD_INSECURE=1)
# OMP_SQUAD_COORDINATOR_TOKEN=         # pre-shared relay secret; clients + coordinator must match. Unset = no auth (loopback only)
# OMP_SQUAD_OPERATOR=                 # operator identity in presence/leases/roster; default = OS username
# OMP_SQUAD_FED_REPOS=                # extra repo paths the federation-sync worker advertises (comma-separated)

# ── Host pressure / watchdog ─────────────────────────────────────────────────
# OMP_SQUAD_RESOURCE_GATE=0           # enable load-aware admission backoff; default off
# OMP_SQUAD_MAX_RSS_MB=1024           # watchdog per-host RSS ceiling (MB)
# OMP_SQUAD_MAX_LOAD_PER_CPU=         # load1/CPU pressure threshold (watchdog 2.0, admission gate 1.5)
# OMP_SQUAD_MIN_FREE_RATIO=0.1        # minimum free-memory ratio before the host counts as pressured

# ── Worktree reaping ─────────────────────────────────────────────────────────
# OMP_SQUAD_WORKTREE_REAP=1           # reap dead worktrees; ON unless 0
# OMP_SQUAD_WORKTREE_GRACE_MS=120000  # grace period before a dead worktree is reaped

# ── Context heat ─────────────────────────────────────────────────────────────
# OMP_SQUAD_HEAT_HALFLIFE_MS=604800000 # context-heat decay half-life (default 7 days)

# ── Web dashboard / push / vision ────────────────────────────────────────────
# OMP_SQUAD_WEBAPP=0                  # 1 serves webapp/dist (the Vite dashboard) when built
# OMP_SQUAD_PUSH_SUBJECT=mailto:squad@localhost # VAPID `sub` contact for Web Push
# OMP_SQUAD_APP_URL=                  # default URL for the vision (screenshot) pass

# ── Feedback Loop (public screenshot intake) ──────────────────────────────────
# OMP_SQUAD_FEEDBACK=0                 # 1 enables public /api/feedback/items and /feedback/widget.js
# OMP_SQUAD_FEEDBACK_MAX_IMAGE_BYTES=2000000 # max PNG/JPEG data URL payload accepted by public intake
# OMP_SQUAD_FEEDBACK_RATE_LIMIT_PER_MIN=30 # coarse in-process per-campaign+IP public intake limit

# ── Discovery ────────────────────────────────────────────────────────────────
# OMP_SQUAD_REPO_ROOTS=               # comma-separated roots scanned for smart-spawn; default <parent of cwd>,~/sui,~/src,~/code

# ── Plane integration ────────────────────────────────────────────────────────
# PLANE_API_KEY=                      # Plane API key
# PLANE_API_TOKEN=                    # alias for PLANE_API_KEY (lets the daemon read a pasted plane.env)
# PLANE_WORKSPACE=                    # Plane workspace slug
# PLANE_WORKSPACE_SLUG=               # alias for PLANE_WORKSPACE
# PLANE_BASE_URL=https://api.plane.so # API base (a trailing /api/v1 is stripped)
# PLANE_PROJECT_ID=                   # fallback project id when a repo is not in PLANE_PROJECT_MAP
# PLANE_PROJECT_MAP=                  # JSON: { "<repo path>": "<plane project id>" }
# PLANE_APP_URL=                      # web app base for deep links; derived from PLANE_BASE_URL if unset

# ── Archil collaborative substrate (PILOT — PARKED; see docs/archil-pilot.md) ─
# Forward-declared config for the Archil agentic-OS substrate pilot (plans/archil-mt-pilot/).
# PARKED: not yet provisioned — we are deliberately NOT paying for an Archil account yet.
# These are read by the throwaway pilot scripts in scripts/ (collab-spike-archil.ts,
# durability-archil.ts) once the pilot is un-parked — NOT by src/. Leave commented until a paid
# Archil account + disk exist. Un-park steps: docs/archil-pilot.md.
# ARCHIL_DISK=                        # disk name or id to mount (the synced "trunk" substrate disk)
# ARCHIL_REGION=aws-us-east-1         # region: aws-us-east-1 | aws-us-west-2 | aws-eu-west-1 (exec/branches need an AWS region)
# ARCHIL_MOUNT_TOKEN=                 # disk token for `archil mount` (the SDK also reads it as ARCHIL_DISK_TOKEN)
