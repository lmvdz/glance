{
  "name": "glance",
  "version": "0.1.0",
  "type": "module",
  "description": "glance — oversight for a fleet of Oh My Pi agents running in parallel across git worktrees. Terminal + web dashboard.",
  "bin": {
    "glance": "src/index.ts",
    "omp-squad": "src/index.ts"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "check": "tsc --noEmit && tsc --noEmit -p webapp/tsconfig.json",
    "prepare": "effect-language-service patch",
    "test": "bun test && cd webapp && bun test"
  },
  "dependencies": {
    "@oh-my-pi/pi-tui": "16.1.7",
    "better-auth": "^1.6.20",
    "effect": "^4.0.0-beta.93",
    "kysely": "^0.29.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.4",
    "@oh-my-pi/pi-coding-agent": "16.1.7",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.14"
  }
}
